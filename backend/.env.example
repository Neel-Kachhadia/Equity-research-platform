# =============================================================================
# AWS S3 — Document Storage
# =============================================================================
# Required IAM permissions:
#   s3:PutObject
#   s3:GetObject
#   s3:HeadObject
#   s3:DeleteObject
#   s3:ListBucket
#
# OCR now uses Google Vision — no Textract permissions needed.
#
# S3 key prefix for OCR uploads:
OCR_S3_PREFIX=ocr-uploads

AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=ap-south-1
S3_BUCKET_NAME=erebus-documents

# S3 key prefix for company JSON data files.
S3_COMPANY_PREFIX=companies/


# =============================================================================
# Google Cloud Vision — OCR Engine
# =============================================================================
# Setup:
#   1. Google Cloud Console → APIs & Services → Enable "Cloud Vision API"
#   2. IAM & Admin → Service Accounts → Create Service Account
#   3. Grant role: "Cloud Vision API User"  (roles/visionai.user)
#   4. Keys → Add Key → JSON → download the JSON file
#
# Option A — point to the JSON file (recommended for local dev):
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
#
# Option B — paste the entire JSON as a single-line string (useful for Docker/CI):
# GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...",...}
#
# Only ONE of the above is needed. Option A takes precedence if both are set.
# If neither is set, the SDK falls back to Application Default Credentials
# (works on GCE / Cloud Run / after running: gcloud auth application-default login)



# =============================================================================
# AWS RDS — PostgreSQL (Metadata & Feature Store)
# =============================================================================
# Setup:
#   1. AWS Console → RDS → Create Database
#   2. Engine: PostgreSQL 15+
#   3. Template: Free Tier  →  db.t4g.micro  (750 hrs/month FREE for 12 months)
#   4. DB instance identifier: erebus-db
#   5. Master username: postgres
#   6. Master password: <set your password>
#   7. Initial database name: erebus
#   8. Publicly accessible: Yes (for development — restrict in production)
#   9. Copy the Endpoint from the RDS dashboard
#
# Format: postgresql://<user>:<password>@<rds-endpoint>:5432/<dbname>
# SSL is required by RDS (ssl_mode=require is set in database.py)

DATABASE_URL=postgresql://postgres:your_password@your-rds-endpoint.ap-south-1.rds.amazonaws.com:5432/erebus

# Set to true to print all SQL queries (for debugging only)
DB_ECHO=false


# =============================================================================
# AWS ElastiCache — Redis (Caching Layer)
# =============================================================================
# Setup:
#   1. AWS Console → ElastiCache → Create → Redis OSS
#   2. Cluster mode: Disabled
#   3. Node type: cache.t3.micro  (~$12/month from your credits)
#   4. Number of replicas: 0  (MVP — add later for HA)
#   5. Enable in-transit encryption: Yes  (ssl=True is set in redis_client.py)
#   6. Copy the Primary Endpoint from the cluster
#
# Format: rediss://<elasticache-endpoint>:6379
# Note: Use rediss:// (double s) when SSL is enabled, redis:// without SSL

REDIS_URL=rediss://your-cluster.abc123.ng.0001.apse1.cache.amazonaws.com:6379

# Set to false to disable caching entirely (system falls back to DB queries)
REDIS_ENABLED=true

# Cache TTL values (in seconds)
# These are defaults — override only if needed
# ttl_default:      3600   (1 hour)   — general cache
# ttl_alpha_scores: 300    (5 min)    — fresh signals needed for trading
# ttl_company_data: 86400  (24 hours) — company metadata changes rarely


# =============================================================================
# Application
# =============================================================================
ENVIRONMENT=development
DEBUG=true

# Required in production — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production


